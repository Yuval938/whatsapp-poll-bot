# WhatsApp
WHATSAPP_GROUP_ID=120363xxxxx@g.us
# Optional: additional groups (comma-separated)
WHATSAPP_GROUP_IDS=
# LocalAuth session profile id (use dedicated value per phone/account)
WHATSAPP_CLIENT_ID=game-bot
DRY_RUN=true

# AI Provider: "anthropic" or "openai"
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Poll analysis assumptions
GROUP_SIZE_ESTIMATE=20

# Logging
LOG_LEVEL=info
